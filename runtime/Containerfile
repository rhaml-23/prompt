# Parameterized Containerfile for compliance fleet agents
# Build with: podman build --build-arg AGENT_TYPE=program -t compliance-agent-program .
# Run with:   podman run -e COMPLIANCE_RUNTIME_MODE=deployed compliance-agent-program

ARG AGENT_TYPE=program

FROM registry.access.redhat.com/ubi9/python-312:latest AS base

LABEL maintainer="compliance-fleet"
LABEL description="Compliance fleet agent — ${AGENT_TYPE}"
LABEL io.k8s.description="Compliance fleet agent for enterprise compliance management"
LABEL io.openshift.tags="compliance,agent,${AGENT_TYPE}"

USER 0

WORKDIR /opt/app-root/src

COPY runtime/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY config/ config/
COPY engine/ engine/
COPY functions/ functions/
COPY agents/ agents/
COPY memory/ memory/
COPY scripts/ scripts/
COPY runtime/ runtime/
COPY tests/ tests/

RUN mkdir -p runs data logs drafts ui \
    && chown -R 1001:0 /opt/app-root/src

USER 1001

ENV COMPLIANCE_RUNTIME_MODE=deployed
ENV AGENT_TYPE=${AGENT_TYPE}
ENV PYTHONUNBUFFERED=1

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "from runtime.factory import create_runtime; print('healthy')" || exit 1

CMD ["python", "-m", "runtime.entrypoint"]
